# Database Configuration
# ⚠️ Change these for any non-local deployment
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gnafer
DB_HOST=localhost
DB_PORT=5432

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Trigram Matcher
TRIGRAM_WORKERS=16
STREET_TYPES_PSV=data/Authority_Code_STREET_TYPE_AUT_psv.psv

# LLM Verification
LLM_VERIFY_THRESHOLD=0.8
LLM_VERIFY_MODEL=qwen2.5:latest

# Observability
LOGTAIL_TOKEN=your_token_here

# Alerting
HEALTHCHECKS_UUID=your_uuid_here

# Ingestion
GNAF_CSV_PATH=data/GNAF_CORE.psv
