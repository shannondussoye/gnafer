# Database Configuration
# ⚠️ Change these for any non-local deployment
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gnafer
DB_HOST=localhost
DB_PORT=5432

# Ollama Configuration
# 💡 Use http://host.docker.internal:11434 if running the API inside Docker on Linux/macOS
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# Trigram Matcher
TRIGRAM_WORKERS=16
STREET_TYPES_PSV=data/Authority_Code_STREET_TYPE_AUT_psv.psv

# LLM Verification
LLM_VERIFY_THRESHOLD=0.8
LLM_BATCH_SIZE=15

# Job / API Configuration
JOB_TTL_SECONDS=3600
JOB_MAX_STORE_SIZE=1000
MAX_BATCH_SIZE=10000

# Observability
LOGTAIL_TOKEN=your_token_here

# Ingestion
GNAF_CSV_PATH=data/GNAF_CORE.psv
